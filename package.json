{
  "name": "jb",
  "version": "1.1.0",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aid7n/jb"
  },
  "scripts": {
    "lint": "turbo run lint --",
    "typecheck": "turbo run typecheck --",
    "cs": "changeset",
    "cs:tag": "changeset tag",
    "cs:empty": "changeset --empty",
    "cs:check": "changeset status --since=origin/main",
    "ci:publish": "for dir in packages/*; do (cd \"$dir\" && bun publish || true); done && changeset tag",
    "dev": "turbo run dev --",
    "build": "turbo run build --",
    "build:all": "bun ./build.ts bun-windows-x64 && bun ./build.ts bun-windows-arm64 && bun ./build.ts bun-darwin-x64 && bun ./build.ts bun-darwin-arm64 && bun ./build.ts bun-linux-x64 && bun ./build.ts bun-linux-arm64",
    "build:win-x64": "bun ./build.ts bun-windows-x64",
    "build:win-arm64": "bun ./build.ts bun-windows-arm64",
    "build:mac-x64": "bun ./build.ts bun-darwin-x64",
    "build:mac-arm64": "bun ./build.ts bun-darwin-arm64",
    "build:linux-x64": "bun ./build.ts bun-linux-x64",
    "build:linux-arm64": "bun ./build.ts bun-linux-arm64",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "husky": "^9.1.7",
    "turbo": "^2.8.10"
  },
  "catalog": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.2",
    "eslint": "^10.7.0",
    "prettier": "^3.5.3",
    "@inquirer/prompts": "^8.5.2",
    "eslint-plugin-turbo": "^2.10.4",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-only-warn": "^1.1.0",
    "typescript": "^6",
    "typescript-eslint": "^8.63.0"
  }
}
