{
  "name": "bun-jfrog",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aid7n/bun-jfrog"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "start": "./dist/yarn",
    "dev": "bun run --watch src/index.ts",
    "build": "bun ./build.ts",
    "build:all": "bun ./build.ts bun-windows-x64 && bun ./build.ts bun-windows-arm64 && bun ./build.ts bun-darwin-x64 && bun ./build.ts bun-darwin-arm64 && bun ./build.ts bun-linux-x64 && bun ./build.ts bun-linux-arm64",
    "build:win-x64": "bun ./build.ts bun-windows-x64",
    "build:win-arm64": "bun ./build.ts bun-windows-arm64",
    "build:mac-x64": "bun ./build.ts bun-darwin-x64",
    "build:mac-arm64": "bun ./build.ts bun-darwin-arm64",
    "build:linux-x64": "bun ./build.ts bun-linux-x64",
    "build:linux-arm64": "bun ./build.ts bun-linux-arm64"
  },
  "dependencies": {
    "semver": "^7"
  },
  "devDependencies": {
    "eslint": "^9.34.0",
    "@types/bun": "^1.3.2",
    "@types/semver": "^7.7.1",
    "@eslint/js": "^9.34.0",
    "typescript": "^6",
    "typescript-eslint": "^8.63.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-only-warn": "^1.1.0"
  }
}
