{
  "name": "@7x/jb-core",
  "version": "1.0.4",
  "private": false,
  "license": "MIT",
  "files": [
    "src",
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aid7n/jb",
    "directory": "packages/core"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "dev": "bun run --watch src/main.ts --jbdev",
    "build": "bun ./src/build.ts all",
    "build:types": "tsc --noEmit false",
    "build:generic": "bun ./src/build.ts"
  },
  "exports": {
    ".": {
      "default": "./src/jb.ts",
      "types": "./dist/jb.d.ts",
      "import": "./dist/jb.js"
    },
    "./types": {
      "default": "./src/types.ts",
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./parser": {
      "default": "./src/parser.ts",
      "types": "./dist/parser.d.ts",
      "import": "./dist/parser.js"
    }
  },
  "dependencies": {
    "semver": "^7",
    "dotenv": "^17",
    "@inquirer/prompts": "catalog:"
  },
  "devDependencies": {
    "@7x/jb-config": "workspace:*",
    "@types/semver": "^7.7.1",
    "@eslint/js": "catalog:",
    "@types/bun": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-only-warn": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "prettier": "catalog:"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
